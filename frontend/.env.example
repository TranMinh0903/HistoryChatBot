VITE_API_BASE_URL=http://localhost:5000/api
# Bỏ trống VITE_API_BASE_URL để chạy chế độ DEMO (mock, không cần backend).

# Google OAuth Client ID (cho nút "Đăng nhập với Google").
# Tạo tại https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID (Web).
# Authorized JavaScript origins: http://localhost:5173 (dev) + domain deploy.
# Bỏ trống → nút Google tự ẩn.
VITE_GOOGLE_CLIENT_ID=
