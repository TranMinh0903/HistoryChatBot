# Biến môi trường cho docker compose (backend). Copy thành .env và điền giá trị.
# .env đã được gitignore — KHÔNG commit key thật.

# Groq API key — bật trả lời AI (console.groq.com)
GROQ_API_KEY=

# Google OAuth Client ID — nút "Đăng nhập với Google" (console.cloud.google.com)
GOOGLE_CLIENT_ID=

# Gemini API key — embedding cho RAG (aistudio.google.com/apikey). Model gemini-embedding-001.
GEMINI_API_KEY=
